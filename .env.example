NODE_ENV=development
PORT=3000
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nestjs_boilerplate
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nestjs_boilerplate?schema=public"
JWT_ACCESS_SECRET="replace-with-a-strong-access-secret"
JWT_REFRESH_SECRET="replace-with-a-strong-refresh-secret"
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_ACCESS_COOKIE_MAX_AGE=900000
AUTH_REFRESH_COOKIE_MAX_AGE=604800000
