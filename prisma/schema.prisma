generator client {
    provider     = "prisma-client"
    output       = "../src/generated/prisma"
    moduleFormat = "cjs"
}

datasource db {
    provider = "postgresql"
}

enum UserRole {
    USER
    ADMIN
}

model User {
    id               String   @id @default(uuid())
    name             String
    email            String   @unique
    password         String
    role             UserRole @default(USER)
    refreshTokenHash String?
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt
}
